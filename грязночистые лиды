--=========================================================
-- 1. Целевые проекты (без изменений)
--=========================================================
drop table if exists tt_projects;
create temp table tt_projects as
select
        sp."CtaRepositoryId"
        ,li."project_id"
        ,sp."Дата создания проекта"
        ,sp."МОП"
        ,sp."Центр прибыли"
        ,max(case when li."comment" ilike '%лид дкс%' then 1 else 0 end) as "Флаг с комментарием" --- заменить впоследствии комментарий
from
        voipclient.leasing_interaction as li
        join voipclient.leasing_task t
                on li.task = t.id
        join voipclient.leasing_campaign lc
                on t.campaign = lc.id
                and lc."type" = 1 -- Исходящий канал ДКС
        join dwh."SAFO_Project" sp
                on li."project_id" = sp."Номер проекта"
where
        li.project_id is not null
        and sp."Дата создания проекта" >= '2026-03-01' --- заменить на дату старта
        and sp."Дата создания проекта" <= now()
group by
        sp."CtaRepositoryId"
        ,li."project_id"
        ,sp."Дата создания проекта"
        ,sp."МОП"
        ,sp."Центр прибыли"
;

--=========================================================
-- 2. Текущий статус проекта (без изменений)
--=========================================================
drop table if exists tt_statuses;
create temp table tt_statuses as
with
base as (
        select
                sp."CtaRepositoryId"
                ,sp."project_id" as "Номер проекта"
                ,sp."Дата создания проекта"
                ,sp."МОП"
                ,sp."Центр прибыли"
                ,sp."Флаг с комментарием"
                ,max(spsl."Curr_DateTime") over (partition by sp."project_id") = spsl."Curr_DateTime" as current_status
                ,pt."Name" as "Статус проекта"
        from
                tt_projects sp
                join dwh."SAFO_Projects_StatusLog" spsl
                        on sp."project_id" = spsl."ProjectId"
                join safo."Projects_Status" pt
                        on spsl."Curr_StatusId" = pt."id"
)
select
        b."CtaRepositoryId"
        ,b."Номер проекта"
        ,b."Дата создания проекта"
        ,b."МОП"
        ,b."Центр прибыли"
        ,b."Флаг с комментарием"
        ,b."Статус проекта"
from
        base b
where
        current_status
;

--=========================================================
-- 3. Итоговая витрина: передачи + покупки + дни до покупки
--=========================================================
drop table if exists tt_projects_mop;
create temp table tt_projects_mop as
with
-- покупки в течение 60 дней после заведения проекта
-- + дата первой покупки для расчёта расстояния в днях
purchases as (
        select
                p."Номер проекта"
                ,max(case when ap."Источник" =  'ЕП' then 1 else 0 end) as "Факт покупки в ЕП"
                ,max(case when ap."Источник" <> 'ЕП' then 1 else 0 end) as "Факт покупки не в ЕП"
                ,min(ap."ДатаПокупки") as "Дата первой покупки"
        from
                tt_statuses p
                join dwh."AllPurchases" ap
                        on ap."CtaRepositoryId" = p."CtaRepositoryId"
                        and ap."ДатаПокупки" between p."Дата создания проекта"
                                and (p."Дата создания проекта" + interval '60 days')
                        and ap."ActualRow" = 1
        group by
                p."Номер проекта"
)
select
        p."Номер проекта"
        ,exists(select 1
                from dwh."IC_ДоговорЛизинга" dl
                where p."Номер проекта" = dl."ProjectId"
                        and dl."ПризнакПередачи" = 'Передан') as "Проект передан в ЕП"
        ,case
                when tbi."Покупки в ЕП в теч 135 дней после закрытия задачи" > 0 then true
                else false
         end as "Факт атрибутивной передачи"
        ,sum(ic."ЧИ") as "ЧИ (прямые и атрибутивные передачи)"
        ,p."Флаг с комментарием"
        ,case when p."Флаг с комментарием" = 1 then 0 else 1 end as "Флаг без комментария"
        ,coalesce(pu."Факт покупки не в ЕП", 0) as "Факт покупки не в ЕП"
        ,coalesce(pu."Факт покупки в ЕП", 0)    as "Факт покупки в ЕП"
        -- расстояние в днях от заведения проекта до первой покупки (рынок или ЕП);
        -- NULL = покупки в окне 60 дней не было
        ,pu."Дата первой покупки"::date - p."Дата создания проекта"::date as "Дней до покупки"
        ,p."Статус проекта"
        ,p."МОП"
        ,p."Центр прибыли"
from
        tt_statuses p
        join ds."DCC_Tasks_BA_Info" tbi
                on tbi."ProjectId" = p."Номер проекта"
        left join dwh."IC_ДоговорЛизинга" ic
                on ic."CtaRepositoryId" = p."CtaRepositoryId"
                and ic."ПризнакПередачи" = 'Передан'
                and ic."ДатаПередачи" between p."Дата создания проекта"
                        and (p."Дата создания проекта" + interval '135 days')
        left join purchases pu
                on pu."Номер проекта" = p."Номер проекта"
group by
        p."Номер проекта"
        ,p."Статус проекта"
        ,p."МОП"
        ,p."Центр прибыли"
        ,"Проект передан в ЕП"
        ,"Факт атрибутивной передачи"
        ,p."Флаг с комментарием"
        ,pu."Факт покупки не в ЕП"
        ,pu."Факт покупки в ЕП"
        ,"Дней до покупки"
;

select * from tt_projects_mop;
